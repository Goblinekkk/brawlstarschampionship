<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Brawl Stars Czechia</title>

  <link rel="stylesheet" href="style.css">

  <script type="module" src="firebase-config.js"></script>
  <script type="module" src="script.js"></script>
</head>
<body>

  <div class="container">

    <h1>Brawl Stars Czechia</h1>

    <button id="googleLogin">
      Sign In with Google
    </button>

    <div id="profile" class="hidden">

      <img id="avatar">

      <h2 id="name"></h2>

      <input
        id="tag"
        placeholder="#2PPQ8YV"
      >

      <button id="saveTag">
        Register
      </button>

    </div>

    <div id="players"></div>

  </div>

</body>
</html>
